<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project</title>
    <link rel="stylesheet" href="/stylesheet/style.css"/>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <!-- <h1>Home Page</h1>
    <p>this is home page using ejs .</p> -->

    <div class="main w-full min-h-screen bg-zinc-900 p-5 ">

    <!-- Form -->
    <form class="flex flex-col gap-4 max-w-sm ">

        <input 
            class="px-5 py-3 bg-zinc-100 rounded w-full" 
            type="text" 
            placeholder="Title goes here"
        >

        <textarea 
            class="px-5 py-3 resize-none bg-zinc-100 rounded w-full" 
            placeholder="Write your task details here"
        ></textarea>

        <!-- Small Button -->
        <input 
            type="submit" 
            value="Create Task" 
            class="bg-red-400 text-white py-2 px-4 rounded cursor-pointer w-fit hover:bg-red-500"
        >

    </form>

    <!-- Tasks -->
    <div class="tasks mt-6 text-white flex flex-row gap-10 ">

        <% files.forEach((val)=>{
            %> <%
        })%>

        <!-- Small Card -->
        <div class="bg-zinc-800 p-4 rounded mb-3 w-fit">
            <h3 class="font-bold">Sample Title</h3>
            <p class="text-sm text-zinc-300">Sample description goes here...</p>
        </div>

        <div class="bg-zinc-800 p-4 rounded mb-3 w-fit">
            <h3 class="font-bold">Another Task</h3>
            <p class="text-sm text-zinc-300">More details here...</p>
        </div>

    </div>

</div>


    <script src="/javascripts/script.js"></script>
</body>
</html>